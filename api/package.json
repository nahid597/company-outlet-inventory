{
  "name": "api",
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "echo \"Add eslint rules in Phase 1\"",
    "format": "prettier --check .",
    "test": "jest --passWithNoTests",
    "typeorm:migrate": "node --require ts-node/register ./node_modules/typeorm/cli.js -d src/db/data-source.ts migration:run",
    "typeorm:revert": "node --require ts-node/register ./node_modules/typeorm/cli.js -d src/db/data-source.ts migration:revert",
    "seed": "ts-node src/db/seed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.28",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.4.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.39.4",
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typeorm-ts-node-commonjs": "^0.3.20",
    "typescript": "^5.9.3"
  }
}